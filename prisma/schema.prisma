// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64"] // Add this line!
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// CORE SYSTEM: NEXTAUTH REQUIRED TABLES
// ==========================================
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // System Links
  accounts Account[]
  sessions Session[]

  // ==========================================
  // W05 TELEMETRY: CUSTOM USER DATA
  // ==========================================
  ieltsModules    IeltsModule[]
  tasks           Task[]
  dailyCommand    DailyCommand?
  researchItems   ResearchExtraction[]
  fitnessLog      FitnessLog? // Sector Epsilon Link
  researchProject ResearchProject? // Sector Delta Link
  notifications   Notification[] // Sector Zeta Link
  ankiTelemetry   AnkiTelemetry?

  // ==========================================
  // W08 SECTOR DAS: DOCUMENT/ASSESSMENT STORE
  // ==========================================
  studyDocuments StudyDocument[]
  documentChunks DocumentChunk[]
  attempts       UserAttempt[]
  usage          UserUsage[]
}

// ==========================================
// SECTOR ALPHA: IELTS VAULT
// ==========================================
model IeltsModule {
  id        String   @id @default(cuid())
  text      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt
}

// ==========================================
// SECTOR BETA: DASHBOARD REMINDERS & TASKS
// ==========================================
model Task {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  category  String   @default("GENERAL")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// SECTOR GAMMA: TODAYS COMMAND
// ==========================================
model DailyCommand {
  id        String   @id @default(cuid())
  intent    String
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt
}

// ==========================================
// SECTOR DELTA: RESEARCH HUB MATRIX
// ==========================================
model ResearchExtraction {
  id        String   @id @default(cuid())
  pmid      String?
  title     String
  authors   String?
  journal   String?
  url       String?
  status    String   @default("UNSCREENED")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ==========================================
// SECTOR DELTA: COVIDENCE STATS
// ==========================================
model ResearchProject {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title      String @default("Local Estrogen Formulations and rUTI")
  screening  Int    @default(45)
  fullText   Int    @default(12)
  extraction Int    @default(0)

  updatedAt DateTime @updatedAt
}

// ==========================================
// SECTOR EPSILON: VITALITY MONITOR
// ==========================================
model FitnessLog {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Stored as a JSON string: "[true, false, ...]"
  workoutDays String @default("[false,false,false,false,false,false,false]")
  lastWorkout String @default("Upper Body Hypertrophy")
  streak      Int    @default(0)

  // Hub Telemetry (V3)
  activeCycle  Int    @default(1)
  metrics      String @default("{\"sleepHours\":7,\"sleepMinutes\":30,\"weight\":72.4,\"height\":175,\"water\":2.1}")
  mealsPayload String @default("{\"date\":\"\",\"meals\":[]}")

  updatedAt DateTime @updatedAt
}

// ==========================================
// SECTOR ZETA: COMMS INTEL
// ==========================================
model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  source  String // e.g., "CANVAS", "GMAIL", "SYSTEM"
  title   String
  message String
  time    String // e.g., "10 mins ago" or "10:45 AM"

  createdAt DateTime @default(now())
}

model AnkiTelemetry {
  id     String @id @default(cuid())
  userId String @unique

  // 🤝 Handshake with User (Hand holds the ID)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 📊 Study Metrics
  dueCards      Int      @default(0)
  newCards      Int      @default(0)
  reviewedToday Int      @default(0)
  streak        Int      @default(0)
  lastSync      DateTime @default(now())
}

// ==========================================
// W08 SECTOR DAS: ENUMS
// ==========================================
enum SourceType {
  pdf
  text
  url
}

enum IeltsSection {
  reading
  listening
  writing
  speaking
}

enum AttemptItemType {
  ielts
  case
}

// ==========================================
// W08 SECTOR DAS: DOCUMENT INGEST + VECTOR STORE
// ==========================================
model StudyDocument {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  sourceType  SourceType
  originalUrl String?
  processedAt DateTime?
  createdAt   DateTime   @default(now())

  chunks DocumentChunk[]

  @@index([userId])
}

model DocumentChunk {
  id         String        @id @default(cuid())
  documentId String
  document   StudyDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  // Denormalized owner: lets Phase B filter by userId before the ANN scan
  // (WHERE "userId" = $1 ORDER BY embedding <=> $2) without a join.
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  content    String        @db.Text
  // pgvector column. Prisma has no native vector type, so it is Unsupported;
  // values are written via parameterized raw SQL ($n::vector) and the HNSW
  // index is created in the migration (cannot be expressed in schema).
  embedding  Unsupported("vector(1536)")
  // Always supplied by the raw insert path, so no DB default (avoids drift).
  metadata   Json
  position   Int

  @@index([userId])
  @@index([documentId])
}

// ==========================================
// W08 SECTOR DAS: IELTS ITEM BANK
// ==========================================
model IELTSItem {
  id         String       @id @default(cuid())
  section    IeltsSection
  skill      String
  prompt     String       @db.Text
  answerKey  Json
  difficulty Int
  tags       String[]
}

// ==========================================
// W08 SECTOR DAS: CLINICAL CASE BANK
// ==========================================
model ClinicalCase {
  id        String   @id @default(cuid())
  title     String
  specialty String
  scenario  String   @db.Text
  branches  Json
  citations String[]
}

// ==========================================
// W08 SECTOR DAS: USER ATTEMPTS
// ==========================================
model UserAttempt {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemType    AttemptItemType
  // Polymorphic reference into IELTSItem.id or ClinicalCase.id (no FK by design).
  itemId      String
  response    Json
  score       Float?
  completedAt DateTime?

  @@index([userId])
  @@index([itemType, itemId])
}

// ==========================================
// W08 SECTOR DAS: USAGE / BUDGET METERING
// ==========================================
model UserUsage {
  id              String @id @default(cuid())
  userId          String
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Billing window as "YYYY-MM".
  month           String
  embeddingTokens Int    @default(0)
  chatTokens      Int    @default(0)

  @@unique([userId, month])
  @@index([userId])
}
