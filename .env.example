# ════════════════════════════════════════════════════════════════════════
# VESTRIPPN 3.0 — environment variables
# Copy to `.env.local` and fill in. Everything except the two "Critical" vars
# is optional: a missing integration just disables that feature (see lib/env.ts).
# The boot log prints which integrations are configured.
# ════════════════════════════════════════════════════════════════════════

# ── Critical (app degrades badly without these) ──────────────────────────
# Auth.js session secret. Generate: `openssl rand -base64 32`
AUTH_SECRET=
# Postgres connection string (Prisma).
VESTRIPPN_PRISMA_DATABASE_URL=

# ── Owner / single-operator ──────────────────────────────────────────────
# The owner account email; used to resolve the acting user without sign-in.
OWNER_EMAIL=

# ── Auth providers (optional) ────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINE_CLIENT_ID=
LINE_CLIENT_SECRET=

# ── Canvas telemetry (optional) ──────────────────────────────────────────
# CANVAS_TOKEN is preferred; CANVAS_API_TOKEN is a legacy alias.
CANVAS_TOKEN=
CANVAS_BASE_URL=https://mango-cmu.instructure.com
# Override/extend tracked courses: "26141:HEN-2|27415:HCVS-2"
CANVAS_COURSES=

# ── Assistant / research (optional) ──────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
NCBI_API_KEY=
ELSEVIER_API_KEY=
ELSEVIER_INSTTOKEN=

# ── Notion / comms (optional) ────────────────────────────────────────────
NOTION_API_KEY=
NOTION_DATABASE_ID=
GMAIL_QUERY=

# ── Anki sync add-on (optional) ──────────────────────────────────────────
ANKI_SYNC_EMAIL=
ANKI_SYNC_SECRET=

# ── Web push (exam reminders even when the tab is closed) ─────────────────
# Generate a keypair once:  npx web-push generate-vapid-keys
# Add all three to Vercel env; the daily cron (/api/push/cron) sends milestones.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
# Vercel auto-sends this as `Authorization: Bearer <CRON_SECRET>` to the cron.
CRON_SECRET=
